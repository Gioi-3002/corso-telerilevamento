#calcolo effettivo del DVI: non ha un range fisso dipende dalla scala dei pixel e i bit ervono per definire questa scala 
# l1=NIR l2=red l3=green
#creo un nuovo raster dove ogni pixel è DVI=NIR-Red
#per ogni pixel confronto la risposta nel vicino infrarosso con rispost nel rosso 
dvi1992 <- mato1992[[1]] - mato1992[[2]]
#questo calcolo funziona perche la veg sana ha NIR alto mentre rosso basso perchè lo assorbe quindi DVI alto,suolo nudo invece implica NIR medio RED medio quindi DVI~0 mentre acqua NIr basso e RED basso DVI basso o negativo
# 8 bit, è un esempio teorico di un'immagine che ha 8 bit quindi i suoi pixel possono valere tra 0 e 255 in quanto 2^8=255
di conseguenza calcola il massimo DVI e il minimo DVI
# NIR - red = 255 - 0 = 255 max DVI
# NIR - red = 0 - 255 = -255 min DVI
#questa cosa vale solo però per immagini 8-bit "pura" quindi JPEG, immagini già visualizzate (RGB classico) dati già compressi non per landsat sentinel-2 e dati scientifici grezzi
# NDVI, poi calcola l'NDVI ovvero quello normalizzato che varia da -1 a 1 invece è relativo il bro

(NIR- red)/(NIR + red)

# 8 bit
# NIR - red = (255 - 0) / (255 + 0) = 1 max NDVI
# NIR - red = (0 - 255) / (0 + 255) = -1 min NDVI

# 4 bit
# NIR - red = (15 - 0) / (15 + 0) = 1 max NDVI
# NIR - red = (0 - 15) / (0 + 15) = -1 min NDVI

dvi2006<-mato2006[[(1)]]-mato2006[[(2)]]
#calcolo NDVI di entrambe mato1992 e mato2006
ndvi1992 <- dvi1992 / (mato1992[[(1)]] + mato1992[[(2)]])
ndvi2006 <- dvi2006 / (mato2006[[(1)]] + mato2006[[(2)]])

#im.multiframe(1,2)  --> faccio il multiframe plottando le mie immagini con calcolato ndvi nelle quali vorrei capire bene ciò che si vede e no
